{
  "manifest_version": 3,
  "name": "TMT Bridge Lens v10",
  "version": "10.0.0",
  "description": "A fast, simple browser extension for English, Nepali and Tamang web translation using the Google TMT API.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_title": "TMT Bridge Lens v10",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
    }
  },
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://tmt.ilprl.ku.edu.np/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tmt-bridge-lens-v10@hackathon.local",
      "strict_min_version": "109.0"
    }
  }
}
